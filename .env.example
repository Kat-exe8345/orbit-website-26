# Next.js runtime mode
NODE_ENV="development"

# App/auth
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
DAUTH_CLIENT_ID="replace-with-dauth-client-id"
DAUTH_SECRET="replace-with-dauth-secret"

# Local Postgres connection.
# replace 127.0.0.1/localhost with the name of the postgres service in docker-compose.prod.yml in production
DATABASE_URL="postgresql://orbit_nitt:postgres@localhost:5432/orbit_nitt"
DB_PASSWORD="postgres"

# Payload CMS
PAYLOAD_SECRET="replace-with-a-long-random-secret"

# Optional DAuth debug flow.
DAUTH_DEBUG="false"
DAUTH_DEBUG_REDIRECT_URI="http://localhost:3000/api/dauth-debug/callback"
